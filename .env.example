# Copy this file to .env and fill in the real values for local development.
# For CI/CD and releases, set these as pipeline secrets (GitHub Actions / GitLab CI / etc.)
# Never commit a file with real values.

# Firebase
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_HOSTING_DOMAIN=

# Nakama backend
# Set true and fill the values below to enable online co-op locally.
NAKAMA_ENABLED=false
NAKAMA_HOST=
NAKAMA_API_PORT=7349
NAKAMA_SOCKET_PORT=7350
NAKAMA_SERVER_KEY=
NAKAMA_GAMEPLAY_HOST=
NAKAMA_GAMEPLAY_UDP_PORT=7360
NAKAMA_GAMEPLAY_TOKEN_SECRET=

# Local Docker/Nakama deployment
POSTGRES_PASSWORD=
NAKAMA_CONSOLE_PASSWORD=

# Remote deploy scripts
BADLAND_SERVER_HOST=
BADLAND_SERVER_USER=root
BADLAND_REMOTE_DIR=/root/badland
